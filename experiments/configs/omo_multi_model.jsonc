{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",

  // C. OMO Multi Model
  // 目的：让不同 agent/category 使用不同模型，检验角色分工 + 模型互补是否带来提升。
  // TODO: 将 model 名称替换成本地 OpenCode/Codex 实际可用的模型 ID。

  "agents": {
    "sisyphus": {
      "model": "anthropic/claude-sonnet-4-6"
    },
    "hephaestus": {
      "model": "anthropic/claude-sonnet-4-6"
    },
    "prometheus": {
      "model": "anthropic/claude-sonnet-4-6",
      "prompt_append": "Focus on clarifying assumptions and creating measurable acceptance criteria."
    },
    "atlas": {
      "model": "anthropic/claude-sonnet-4-6"
    },
    "oracle": {
      "model": "anthropic/claude-sonnet-4-6"
    },
    "librarian": {
      "model": "openai/gpt-5.4-mini"
    },
    "explore": {
      "model": "openai/gpt-5.4-mini"
    },
    "metis": {
      "model": "anthropic/claude-sonnet-4-6"
    },
    "momus": {
      "model": "anthropic/claude-sonnet-4-6"
    },
    "sisyphus-junior": {
      "model": "openai/gpt-5.4-mini"
    }
  },

  "categories": {
    "quick": { "model": "openai/gpt-5.4-mini" },
    "unspecified-low": { "model": "openai/gpt-5.4-mini" },
    "unspecified-high": { "model": "anthropic/claude-sonnet-4-6" },
    "writing": { "model": "anthropic/claude-sonnet-4-6" },
    "deep": { "model": "anthropic/claude-sonnet-4-6" },
    "ultrabrain": { "model": "anthropic/claude-sonnet-4-6" }
  },

  "background_task": {
    "defaultConcurrency": 4,
    "providerConcurrency": {
      "openai": 4,
      "anthropic": 3
    }
  },

  "experimental": {
    "aggressive_truncation": true
  }
}

