{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["oh-my-openagent@latest"],
  "provider": {
    "formal-gpt": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Formal GPT API",
      "options": {
        "baseURL": "{env:GPT_BASE_URL}",
        "apiKey": "{env:GPT_API_KEY}"
      },
      "models": {
        "gpt-5.4": {
          "name": "GPT-5.4",
          "limit": {
            "context": 1050000,
            "output": 32768
          }
        }
      }
    }
  }
}
