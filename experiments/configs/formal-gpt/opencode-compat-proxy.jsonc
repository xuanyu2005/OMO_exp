{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["oh-my-openagent@latest"],
  "provider": {
    "formal-gpt-compat-proxy": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Formal GPT API via local compatibility proxy",
      "options": {
        "baseURL": "http://127.0.0.1:18082",
        "apiKey": "formal-compat-proxy-local"
      },
      "models": {
        "gpt-5.4": {
          "name": "GPT-5.4",
          "limit": {
            "context": 1050000,
            "output": 32768
          }
        }
      }
    }
  }
}
