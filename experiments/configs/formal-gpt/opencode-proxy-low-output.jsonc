{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "formal-gpt-proxy-low-output": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Formal GPT API Proxy Low Output",
      "options": {
        "baseURL": "http://127.0.0.1:18081",
        "apiKey": "probe-key"
      },
      "models": {
        "gpt-5.4": {
          "name": "GPT-5.4",
          "limit": {
            "context": 1050000,
            "output": 32768
          }
        }
      }
    }
  }
}
