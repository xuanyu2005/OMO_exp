{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-openagent@latest"
  ],
  "provider": {
    "formal-gpt-proxy": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Formal GPT API Proxy",
      "options": {
        "baseURL": "http://127.0.0.1:18080",
        "apiKey": "probe-placeholder"
      },
      "models": {
        "gpt-5.4": {
          "name": "GPT-5.4",
          "limit": {
            "context": 1050000,
            "output": 32768
          }
        }
      }
    }
  }
}
