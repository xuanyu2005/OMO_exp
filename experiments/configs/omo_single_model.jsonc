{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",

  // B. OMO Single Model
  // 目的：使用 OMO 编排，但尽量排除“多模型能力差异”的影响。
  // TODO: 将 model 名称替换成本地 OpenCode/Codex 实际可用的模型 ID。

  "agents": {
    "sisyphus": { "model": "openai/gpt-5.4-mini" },
    "hephaestus": { "model": "openai/gpt-5.4-mini" },
    "prometheus": { "model": "openai/gpt-5.4-mini" },
    "atlas": { "model": "openai/gpt-5.4-mini" },
    "oracle": { "model": "openai/gpt-5.4-mini" },
    "librarian": { "model": "openai/gpt-5.4-mini" },
    "explore": { "model": "openai/gpt-5.4-mini" },
    "multimodal-looker": { "model": "openai/gpt-5.4-mini" },
    "metis": { "model": "openai/gpt-5.4-mini" },
    "momus": { "model": "openai/gpt-5.4-mini" },
    "sisyphus-junior": { "model": "openai/gpt-5.4-mini" }
  },

  "categories": {
    "quick": { "model": "openai/gpt-5.4-mini" },
    "unspecified-low": { "model": "openai/gpt-5.4-mini" },
    "unspecified-high": { "model": "openai/gpt-5.4-mini" },
    "writing": { "model": "openai/gpt-5.4-mini" },
    "visual-engineering": { "model": "openai/gpt-5.4-mini" },
    "deep": { "model": "openai/gpt-5.4-mini" },
    "ultrabrain": { "model": "openai/gpt-5.4-mini" }
  },

  "background_task": {
    "defaultConcurrency": 3
  },

  "experimental": {
    "aggressive_truncation": true
  }
}

