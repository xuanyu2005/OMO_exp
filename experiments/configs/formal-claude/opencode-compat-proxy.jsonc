{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["oh-my-openagent@latest"],
  "provider": {
    "formal-claude-compat-proxy": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Formal Claude API via local compatibility proxy",
      "options": {
        "baseURL": "http://127.0.0.1:18082",
        "apiKey": "formal-compat-proxy-local"
      },
      "models": {
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6",
          "limit": {
            "context": 200000,
            "output": 32768
          }
        }
      }
    }
  }
}
